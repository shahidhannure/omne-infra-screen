{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "api-route": {
        "ClusterId": "api-cluster",
        "Match": { "Path": "/api/{**catch-all}" }
      }
    },
    "Clusters": {
      "api-cluster": {
        "Destinations": {
          "api": {
            "_comment": "Overridden at runtime via ReverseProxy__Clusters__api-cluster__Destinations__api__Address",
            "Address": "http://localhost:5080/"
          }
        }
      }
    }
  }
}
