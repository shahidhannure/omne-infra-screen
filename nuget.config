<?xml version="1.0" encoding="utf-8"?>
<!--
  Public feed only, so the slice restores without any Omne credentials.
  (The real monorepo also pulls from a private GitHub Packages feed.)
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
